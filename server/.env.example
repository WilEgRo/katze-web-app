# Configuración del servidor
PORT=8080

# Base de datos MongoDB
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>/<database>?retryWrites=true&w=majority&appName=<appName>

# JWT
JWT_SECRET=CAMBIA_ESTA_CLAVE_SUPER_SECRETA

# Credenciales de Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# credenciales gemini
GOOGLE_API_KEY=tu_gemini_api_key

# URL principal de frontend (produccion)
FRONTEND_URL=https://katze-web-app.vercel.app

# Origenes adicionales separados por coma (staging, previews, etc.)
# Ejemplo: https://katze-web-app-git-dev-tuusuario.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173